# Environment Variables Example

# Node Environment
NODE_ENV=development
API_PORT=3000

# Database Configuration (Docker default)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=used_car_intelligence
DB_PORT=5432

# Prisma Database URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/used_car_intelligence?schema=public

# Security
JWT_SECRET=super-secret-jwt-key-change-in-production

# App URLs
ADMIN_APP_URL=http://localhost:3001
MOBILE_API_URL=http://localhost:3000
