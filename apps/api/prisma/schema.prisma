datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionTier {
  FREE
  STANDARD
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
  TRIALING
}

enum ApprovalStatus {
  RAW
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
  STALE
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProblemType {
  COMMON_PROBLEM
  USER_COMPLAINT
  CHECK_POINT
  SERVICE_NOTE
  RECALL_RELATED
  GENERAL_RISK
}

enum ResearchScope {
  FULL_REPORT
  COMMON_PROBLEMS
  RECALLS
  SELLER_QUESTIONS
  INSPECTION_CHECKLIST
  TECHNICAL_SPECS
}

enum SourceKind {
  OFFICIAL_RECALL
  MANUFACTURER
  SERVICE_NOTE
  USER_REVIEW
  FORUM
  COMPLAINT_PLATFORM
  BLOG_REVIEW
  VIDEO_REVIEW
  ADMIN_DEMO
  UNKNOWN
  MOCK
}

enum DataConfidence {
  LOW
  MEDIUM
  HIGH
}

enum ResearchJobStatus {
  QUEUED
  RUNNING
  NEEDS_REVIEW
  COMPLETED
  FAILED
  CANCELLED
}

enum DataCoverage {
  NONE
  LIMITED
  MODERATE
  GOOD
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  DCT
  CVT
}

enum FeatureKey {
  AI_CHAT
  VEHICLE_COMPARISON
}

enum UsagePeriodType {
  DAILY
  MONTHLY
  LIFETIME
}

enum SourceType {
  TECHNICAL_SPEC
  COMMON_PROBLEM
  RECALL
  USER_COMPLAINT
  SERVICE_NOTE
  MANUAL
  OTHER
}

enum FuelType {
  PETROL
  DIESEL
  LPG
  HYBRID
  PLUG_IN_HYBRID
  ELECTRIC
  OTHER
}

enum BodyType {
  SEDAN
  HATCHBACK
  SUV
  COUPE
  WAGON
  PICKUP
  VAN
  CONVERTIBLE
  MINIVAN
  OTHER
}

enum VehicleInfoCategory {
  ENGINE
  TRANSMISSION
  ELECTRONICS
  SUSPENSION
  BRAKE
  BODY
  PAINT
  INTERIOR
  TIRES
  TEST_DRIVE
  MAINTENANCE
  DOCUMENTS
  GENERAL
}

enum FinalDecision {
  BUY
  BUY_CAREFULLY
  RISKY
  AVOID
  INSUFFICIENT_DATA
  BUYABLE
  BUY_WITH_CAUTION
}

enum DisplayNamePreference {
  FULL_NAME
  SHORT_NAME
  USERNAME
}

model User {
  id                     String            @id @default(uuid())
  email                  String            @unique
  passwordHash           String
  role                   Role              @default(USER)
  subscriptionTier       SubscriptionTier  @default(FREE)
  preferredLanguageCode  String?
  preferredCountryId     String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  
  username               String?           @unique
  firstName              String?
  lastName               String?
  phone                  String?           @unique
  phoneVerifiedAt        DateTime?
  emailVerifiedAt        DateTime?
  profilePhotoUrl        String?
  displayNamePreference  DisplayNamePreference @default(FULL_NAME)
  notificationSettings   Json?
  isActive               Boolean           @default(true)

  subscriptions      Subscription[]
  reviews            UserReview[]
  favorites          FavoriteVehicle[]
  favoriteListings   FavoriteListing[]
  comparisons        VehicleComparison[]
  chatLogs           AiChatLog[]
  auditLogs          AuditLog[]
  featureUsages      FeatureUsage[]
  guideViewHistories UserGuideCardViewHistory[]

  savedSearches          SavedSearch[]
  favoriteSellers        FavoriteSeller[]          @relation("FavoriteSellerUser")
  favoritedBy            FavoriteSeller[]          @relation("FavoriteSellerSeller")
  conversationsAsBuyer   Conversation[]            @relation("BuyerConversations")
  conversationsAsSeller  Conversation[]            @relation("SellerConversations")
  sentMessages           Message[]

  preferredCountry   Country?                  @relation("UserPreferredCountry", fields: [preferredCountryId], references: [id])
  createdVariants    VehicleVariant[]          @relation("VariantCreatedBy")
  approvedVariants   VehicleVariant[]          @relation("VariantApprovedBy")
  createdProblems    CommonProblem[]           @relation("ProblemCreatedBy")
  approvedProblems   CommonProblem[]           @relation("ProblemApprovedBy")
  createdRecalls     Recall[]                  @relation("RecallCreatedBy")
  approvedRecalls    Recall[]                  @relation("RecallApprovedBy")
  createdQuestions   SellerQuestion[]          @relation("QuestionCreatedBy")
  approvedQuestions  SellerQuestion[]          @relation("QuestionApprovedBy")
  createdChecklists  InspectionChecklistItem[] @relation("ChecklistCreatedBy")
  approvedChecklists InspectionChecklistItem[] @relation("ChecklistApprovedBy")
  researchJobs       VehicleResearchJob[]
  listings           VehicleListing[]
}

model SubscriptionPlan {
  id        String           @id @default(uuid())
  tier      SubscriptionTier @unique
  name      String
  priceTrl  Decimal
  priceUsd  Decimal
  limits    Json             // AI soru limitleri, karşılaştırma limitleri vb.
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  
  subscriptions Subscription[]
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user      User               @relation(fields: [userId], references: [id])
  plan      SubscriptionPlan   @relation(fields: [planId], references: [id])
}

model FeatureUsage {
  id          String          @id @default(uuid())
  userId      String
  featureKey  FeatureKey
  periodType  UsagePeriodType
  periodStart DateTime
  count       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey, periodType, periodStart])
}

model Country {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  createdAt   DateTime         @default(now())
  
  variants    VehicleVariant[]
  recalls     Recall[]
  preferredBy User[]           @relation("UserPreferredCountry")
}

model Language {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations BrandTranslation[]
  models       Model[]
  variants     VehicleVariant[]
}

model BrandTranslation {
  id           String   @id @default(uuid())
  brandId      String
  languageCode String
  name         String
  
  brand        Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  @@unique([brandId, languageCode])
  @@index([languageCode])
}

model Model {
  id        String   @id @default(uuid())
  brandId   String
  name      String
  startYear Int
  endYear   Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand        Brand              @relation(fields: [brandId], references: [id])
  translations ModelTranslation[]
  generations  Generation[]
  variants     VehicleVariant[]

  @@unique([brandId, name])
}

model ModelTranslation {
  id           String   @id @default(uuid())
  modelId      String
  languageCode String
  name         String
  
  model        Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  @@unique([modelId, languageCode])
  @@index([languageCode])
}

model Generation {
  id          String   @id @default(uuid())
  modelId     String
  name        String
  startYear   Int
  endYear     Int?
  bodyType    BodyType
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  model        Model                   @relation(fields: [modelId], references: [id])
  translations GenerationTranslation[]
  variants     VehicleVariant[]

  @@unique([modelId, name, startYear, bodyType])
}

model GenerationTranslation {
  id           String     @id @default(uuid())
  generationId String
  languageCode String
  description  String
  
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  @@unique([generationId, languageCode])
  @@index([languageCode])
}

model Engine {
  id           String   @id @default(uuid())
  code         String
  displacement Int
  horsepower   Int
  torque       Int
  fuelType     FuelType
  hasTurbo     Boolean  @default(false)
  isHybrid     Boolean  @default(false)
  isElectric   Boolean  @default(false)
  description  String?
  createdAt    DateTime @default(now())

  variants     VehicleVariant[]

  @@unique([code, displacement, horsepower, torque, fuelType])
}

model Transmission {
  id        String           @id @default(uuid())
  name      String
  type      TransmissionType
  speeds    Int
  createdAt DateTime         @default(now())

  variants  VehicleVariant[]

  @@unique([name, type, speeds])
}

model Trim {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  translations TrimTranslation[]
  variants     VehicleVariant[]
}

model TrimTranslation {
  id           String   @id @default(uuid())
  trimId       String
  languageCode String
  description  String
  
  trim         Trim     @relation(fields: [trimId], references: [id], onDelete: Cascade)
  @@unique([trimId, languageCode])
  @@index([languageCode])
}

model VehicleVariant {
  id             String         @id @default(uuid())
  brandId        String
  modelId        String
  generationId   String
  engineId       String
  transmissionId String
  trimId         String
  countryId      String
  year           Int
  yearStart      Int?
  yearEnd        Int?
  bodyType       BodyType?
  fuelType       FuelType?
  marketRegion   String?
  status         ApprovalStatus @default(PENDING)
  createdById    String?
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  brand        Brand        @relation(fields: [brandId], references: [id])
  model        Model        @relation(fields: [modelId], references: [id])
  generation   Generation   @relation(fields: [generationId], references: [id])
  engine       Engine       @relation(fields: [engineId], references: [id])
  transmission Transmission @relation(fields: [transmissionId], references: [id])
  trim         Trim         @relation(fields: [trimId], references: [id])
  country      Country      @relation(fields: [countryId], references: [id])

  createdBy    User?        @relation("VariantCreatedBy", fields: [createdById], references: [id])
  approvedBy   User?        @relation("VariantApprovedBy", fields: [approvedById], references: [id])

  specs        TechnicalSpec?
  problems     CommonProblem[]
  recalls      Recall[]
  reviews      UserReview[]
  favorites    FavoriteVehicle[]
  comparisons1 VehicleComparison[] @relation("Variant1Comparisons")
  comparisons2 VehicleComparison[] @relation("Variant2Comparisons")
  chatLogs     AiChatLog[]
  questions    SellerQuestion[]
  checklists   InspectionChecklistItem[]
  aiReports    AiVehicleReport[]
  researchJobs VehicleResearchJob[]
  rawSources   RawSource[]
  listings     VehicleListing[]

  @@unique([brandId, modelId, generationId, engineId, transmissionId, trimId, countryId, year])
  @@index([brandId])
  @@index([modelId])
  @@index([countryId])
  @@index([year])
  @@index([status])
  @@index([brandId, modelId, countryId, year])
}

model TechnicalSpec {
  id        String         @id @default(uuid())
  variantId String         @unique
  specs     Json
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  variant   VehicleVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model CommonProblem {
  id                 String         @id @default(uuid())
  variantId          String
  title              String
  description        String
  affectedYears      String?
  affectedEngine     String?
  affectedTransmission String?
  riskLevel          RiskLevel      @default(MEDIUM)
  symptoms           String?
  checkRecommendation String?
  sourceUrl          String?
  confidenceScore    Decimal        @default(1.0)
  status             ApprovalStatus @default(PENDING)
  problemType        ProblemType    @default(COMMON_PROBLEM)
  inspectionAdvice   String?
  dataConfidence     DataConfidence @default(MEDIUM)
  sourceKind         SourceKind     @default(UNKNOWN)
  affectedTrim       String?
  sourceCount        Int            @default(1)
  evidenceSummary    String?
  lastCheckedAt      DateTime?
  rejectedAt         DateTime?
  createdById        String?
  approvedById       String?
  approvedAt         DateTime?
  rejectedReason     String?
  metadata           Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  variant      VehicleVariant               @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdBy    User?                        @relation("ProblemCreatedBy", fields: [createdById], references: [id])
  approvedBy   User?                        @relation("ProblemApprovedBy", fields: [approvedById], references: [id])
  translations CommonProblemTranslation[]
  sources      CommonProblemSource[]

  @@index([variantId, status])
}

model CommonProblemTranslation {
  id                  String        @id @default(uuid())
  problemId           String
  languageCode        String
  title               String
  description         String
  symptoms            String?
  checkRecommendation String?

  problem             CommonProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  @@unique([problemId, languageCode])
  @@index([languageCode])
}

model Recall {
  id              String         @id @default(uuid())
  variantId       String
  title           String
  description     String
  countryId       String
  date            DateTime
  sourceUrl       String?
  riskLevel       RiskLevel      @default(HIGH)
  status          ApprovalStatus @default(PENDING)
  vinCheckRequired            Boolean        @default(true)
  officialCheckUrl            String?
  recallDate                  DateTime?
  remedy                      String?
  manufacturerCampaignNumber  String?
  nhtsaCampaignNumber         String?
  safetyRisk                  String?
  recallCode                  String?
  officialSourceUrl           String?
  sourceKind                  SourceKind     @default(OFFICIAL_RECALL)
  affectedYears               String?
  affectedEngine              String?
  affectedTransmission        String?
  countryCode                 String?
  dataConfidence              DataConfidence @default(HIGH)
  lastCheckedAt               DateTime?
  createdById     String?
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  variant         VehicleVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  country         Country        @relation(fields: [countryId], references: [id])
  createdBy       User?          @relation("RecallCreatedBy", fields: [createdById], references: [id])
  approvedBy      User?          @relation("RecallApprovedBy", fields: [approvedById], references: [id])
  sources         RecallSource[]

  @@index([variantId, status])
}

model SellerQuestion {
  id              String              @id @default(uuid())
  variantId       String
  question        String
  reason          String?
  category        VehicleInfoCategory
  riskLevel       RiskLevel           @default(MEDIUM)
  priority        PriorityLevel       @default(MEDIUM)
  sourceUrl       String?
  confidenceScore Decimal             @default(1.0)
  status          ApprovalStatus      @default(PENDING)
  createdById     String?
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  variant       VehicleVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("QuestionCreatedBy", fields: [createdById], references: [id])
  approvedBy    User?          @relation("QuestionApprovedBy", fields: [approvedById], references: [id])

  translations  SellerQuestionTranslation[]

  @@index([variantId, status])
}

model SellerQuestionTranslation {
  id               String         @id @default(uuid())
  sellerQuestionId String
  languageCode     String
  question         String
  reason           String?

  sellerQuestion   SellerQuestion @relation(fields: [sellerQuestionId], references: [id], onDelete: Cascade)

  @@unique([sellerQuestionId, languageCode])
  @@index([languageCode])
}

model InspectionChecklistItem {
  id              String              @id @default(uuid())
  variantId       String
  title           String
  description     String?
  category        VehicleInfoCategory
  riskLevel       RiskLevel           @default(MEDIUM)
  priority        PriorityLevel       @default(MEDIUM)
  sortOrder       Int                 @default(0)
  sourceUrl       String?
  confidenceScore Decimal             @default(1.0)
  status          ApprovalStatus      @default(PENDING)
  createdById     String?
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  variant       VehicleVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("ChecklistCreatedBy", fields: [createdById], references: [id])
  approvedBy    User?          @relation("ChecklistApprovedBy", fields: [approvedById], references: [id])

  translations  InspectionChecklistItemTranslation[]

  @@index([variantId, status])
}

model InspectionChecklistItemTranslation {
  id                  String                  @id @default(uuid())
  checklistItemId     String
  languageCode        String
  title               String
  description         String?

  checklistItem       InspectionChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  @@unique([checklistItemId, languageCode])
  @@index([languageCode])
}

model RawSource {
  id              String      @id @default(uuid())
  sourceType      SourceType
  url             String
  title           String?
  contentHash     String      @unique
  extractedText   String?
  languageCode    String      @default("tr")
  countryCode     String      @default("TR")
  marketRegion    String?
  confidenceScore Decimal     @default(1.0)
  vehicleVariantId String?
  sourceKind       SourceKind     @default(UNKNOWN)
  rawText          String?
  extractedSummary String?
  reliabilityScore Decimal?
  lastCheckedAt    DateTime?
  status          ApprovalStatus @default(RAW)
  metadata        Json?
  isVerified      Boolean        @default(false)
  isOfficial      Boolean        @default(false)
  sourceDomain    String?
  fetchedAt       DateTime    @default(now())
  createdAt       DateTime    @default(now())

  variant         VehicleVariant? @relation(fields: [vehicleVariantId], references: [id])
  problems        CommonProblemSource[]
  recalls         RecallSource[]

  @@index([url])
  @@index([vehicleVariantId, status])
}

model CommonProblemSource {
  id                     String        @id @default(uuid())
  problemId              String
  sourceId               String
  sourceUrl              String?
  sourceKind             SourceKind    @default(UNKNOWN)
  evidenceText           String?
  confidenceContribution Decimal?
  createdAt              DateTime      @default(now())

  problem         CommonProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  source          RawSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([problemId, sourceId])
  @@index([problemId])
  @@index([sourceId])
}

model RecallSource {
  id              String        @id @default(uuid())
  recallId        String
  sourceId        String
  createdAt       DateTime      @default(now())

  recall          Recall        @relation(fields: [recallId], references: [id], onDelete: Cascade)
  source          RawSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([recallId, sourceId])
}

model UserReview {
  id            String         @id @default(uuid())
  variantId     String
  userId        String
  comment       String
  usageDuration Int
  isOwner       Boolean        @default(true)
  recommend     Boolean        @default(true)
  status        ApprovalStatus @default(PENDING)
  reviewDateKey String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  variant       VehicleVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating        UserRating?

  @@unique([userId, variantId, reviewDateKey])
  @@index([variantId, status])
  @@index([userId, createdAt])
}

model UserRating {
  id              String     @id @default(uuid())
  reviewId        String     @unique
  reliability     Int
  fuelConsumption Int
  comfort         Int
  partCost        Int
  maintenanceCost Int
  resaleEase      Int
  overall         Int

  review          UserReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model FavoriteVehicle {
  id        String         @id @default(uuid())
  userId    String
  variantId String
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant   VehicleVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  @@unique([userId, variantId])
}

model VehicleComparison {
  id         String   @id @default(uuid())
  userId     String
  variant1Id String
  variant2Id String
  createdAt  DateTime @default(now())

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant1   VehicleVariant @relation("Variant1Comparisons", fields: [variant1Id], references: [id], onDelete: Cascade)
  variant2   VehicleVariant @relation("Variant2Comparisons", fields: [variant2Id], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([variant1Id])
  @@index([variant2Id])
  @@index([createdAt])
}

model AiChatLog {
  id        String   @id @default(uuid())
  userId    String
  variantId String
  prompt    String
  response  String
  createdAt DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant   VehicleVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([variantId])
  @@index([createdAt])
}

model AiVehicleReport {
  id               String         @id @default(uuid())
  variantId        String
  languageCode     String
  summary          Json
  riskScore        Int
  buyabilityScore  Int
  finalDecision    FinalDecision
  biggestRisks     Json?
  sellerQuestions  Json?
  inspectionChecklist Json?
  sourceVersion    String?
  dataCoverage     DataCoverage?
  coverageScore    Decimal?
  status           ApprovalStatus @default(APPROVED)
  generatedAt      DateTime?
  approvedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  variant          VehicleVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, languageCode])
  @@index([languageCode])
  @@index([variantId, languageCode, status])
}

model VehicleResearchJob {
  id                 String             @id @default(uuid())
  vehicleVariantId   String
  status             ResearchJobStatus  @default(QUEUED)
  languageCode       String             @default("tr")
  countryCode        String             @default("TR")
  marketRegion       String?
  researchScope      ResearchScope      @default(FULL_REPORT)
  requestedByUserId  String?
  requestedReason    String?
  priority           PriorityLevel      @default(MEDIUM)
  errorMessage       String?
  attemptCount       Int                @default(0)
  maxAttempts        Int                @default(3)
  lockedAt           DateTime?
  lockedBy           String?
  nextRunAt          DateTime?
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime       @updatedAt

  variant            VehicleVariant     @relation(fields: [vehicleVariantId], references: [id], onDelete: Cascade)
  requestedBy        User?              @relation(fields: [requestedByUserId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PASSIVE
  SOLD
  EXPIRED
  REJECTED
  ARCHIVED
}

enum MediaModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingMediaType {
  IMAGE
  VIDEO
}

enum ListingPackageType {
  FREE
  STANDARD
  PREMIUM
}

model VehicleListing {
  id                 String             @id @default(uuid())
  sellerId           String
  seller             User               @relation(fields: [sellerId], references: [id])
  
  vehicleVariantId   String?            // Nullable only for drafts/variant request flows
  vehicleVariant     VehicleVariant?    @relation(fields: [vehicleVariantId], references: [id])
  
  // Custom metadata if variant does not exist yet (variant request flow)
  customBrand        String?
  customModel        String?
  customYear         Int?
  customEngine       String?
  customTransmission String?
  
  title              String
  description        String?
  
  priceAmount        Decimal            @db.Decimal(12, 2)
  currency           String             @default("TRY")
  
  // Global Location fields
  countryCode        String             @default("TR") // Focuses on Turkey (TR) first
  region             String?            // e.g. State in USA, region, etc.
  city               String             // e.g. İstanbul
  district           String?            // e.g. Kadıköy
  
  modelYear          Int
  kilometers         Int
  fuelType           FuelType?
  transmission       TransmissionType?
  bodyType           BodyType?
  color              String?
  
  // Extended Specifications & Filters
  vehicleStatus      String?            // e.g. "USED", "NEW", "IMPORTED_NEW"
  hasWarranty        Boolean            @default(false)
  heavyDamage        Boolean            @default(false)
  plateType          String?            // e.g. "TR_PLATE", "MA_PLATE", "SPECIAL_PLATE"
  sellerType         String?            // e.g. "OWNER", "DEALER", "AUTHORIZED_DEALER"
  exchangeable       Boolean            @default(false)
  engineDisplacement Int?               // in cc, e.g. 1598
  enginePower        Int?               // in HP, e.g. 110
  drivetrain         String?            // e.g. "FWD", "RWD", "AWD", "AWD_ELECTRONIC"
  
  damageRecord       String?
  tramerAmount       Int?               @default(0)
  paintedParts       Json?              // Array of strings (e.g. ["FRONT_BUMPER"])
  changedParts       Json?              // Array of strings (e.g. ["LEFT_FRONT_DOOR"])
  localPaintedParts  Json?              // Array of strings (e.g. ["ROOF"])
  maintenanceHistory String?
  expertiseReportUrl String?
  
  plateHidden        Boolean            @default(true)
  vinHidden          Boolean            @default(true)
  
  status             ListingStatus      @default(DRAFT)
  isFeatured         Boolean            @default(false)
  isAiReady          Boolean            @default(false)
  
  // Admin moderation & reports metadata
  rejectionReason    String?
  adminNote          String?
  reviewedById       String?
  reviewedAt         DateTime?
  reportCount        Int                @default(0)
  fraudScore         Float              @default(0.0)
  
  // Independent Listing Duration tracking fields
  publishedAt        DateTime?
  expiresAt          DateTime?
  passiveUntil       DateTime?
  lastRenewedAt      DateTime?
  packageAtPublish   ListingPackageType?
  listingDurationDays Int?              // 30 for FREE/STANDARD, 45 for PREMIUM
  
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  
  media              ListingMedia[]
  leads              ListingLead[]
  views              ListingView[]
  favorites          FavoriteListing[]
  conversations      Conversation[]
  
  @@index([vehicleVariantId])
  @@index([sellerId])
  @@index([status])
  @@index([city])
  @@index([priceAmount])
  @@index([createdAt])
  @@index([modelYear])
  @@index([kilometers])
  @@index([countryCode, city])
  @@index([status, expiresAt])
  @@index([status, passiveUntil])
  @@index([sellerId, status])
}

model ListingMedia {
  id               String                @id @default(uuid())
  listingId        String
  listing          VehicleListing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  url              String                // Optimized medium url or fallback
  thumbnailUrl     String?               // WebP thumbnail for list cards
  mediumUrl        String?               // WebP medium version for details page
  storageKey       String                // S3 / Cloudflare R2 object key
  
  type             ListingMediaType      @default(IMAGE)
  sortOrder        Int                   @default(0) // sortOrder = 0 is cover photo
  fileSize         Int                   // In bytes
  mimeType         String                // e.g. "image/webp", "image/jpeg"
  width            Int?
  height           Int?
  
  moderationStatus MediaModerationStatus @default(PENDING)
  createdAt        DateTime              @default(now())
  
  @@index([listingId])
}

model ListingLead {
  id                 String         @id @default(uuid())
  listingId          String
  listing            VehicleListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  buyerId            String?
  buyerName          String
  buyerPhone         String
  buyerEmail         String
  message            String
  ipAddress          String?        // Saved for rate-limiting & anti-spam checks
  communicationGranted Boolean        @default(false) // KVKK / GDPR compliance consent
  replyMessage       String?
  repliedAt          DateTime?
  
  createdAt          DateTime       @default(now())
  
  @@index([listingId])
  @@index([buyerId])
}

model ListingView {
  id          String         @id @default(uuid())
  listingId   String
  listing     VehicleListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  userId      String?
  ipHash      String?
  userAgent   String?
  createdAt   DateTime       @default(now())
  
  @@index([listingId])
  @@index([userId])
}

model FavoriteListing {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   VehicleListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

enum Locale {
  tr
  en
}

enum GuideStatus {
  DRAFT
  REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum GuideFactType {
  INTERESTING_FACT
  BUYING_TIP
  USER_EXPERIENCE
  TECHNICAL_SUMMARY
  KNOWN_ISSUE
  VERSION_NOTE
}

enum GuideSourceType {
  OFFICIAL
  DISTRIBUTOR
  PRESS
  REVIEW
  LISTING
  USER_FEEDBACK
  INTERNAL_RESEARCH
  OTHER
}

enum GuideEventType {
  GUIDE_CARD_VIEW
  GUIDE_CARD_SWIPE_UP
  GUIDE_CARD_SWIPE_DOWN
  GUIDE_CARD_TIME_SPENT
  GUIDE_TECHNICAL_INFO_OPENED
  GUIDE_TECHNICAL_INFO_CLOSED
  GUIDE_LISTING_CTA_CLICKED
  GUIDE_CARD_SHARED
  GUIDE_CARD_FAVORITED
}

model VehicleGuideCard {
  id                  String                         @id @default(uuid())
  brand               String
  model               String
  generationName      String?
  generationCode      String?
  bodyType            String?
  yearStart           Int
  yearEnd             Int?
  heroImageUrl        String?
  imageAltText        String?
  imageSource         String?
  imageLicense        String?
  placeholderImageUrl String?
  imageObjectPosition String?                        @default("center center")
  imageFitMode        String?                        @default("cover")
  licenseLabelPosition String?                       @default("bottom-right")
  shortSummary        String?
  ratingScore         Float?                         @default(0.0)
  ratingCount         Int                            @default(0)
  status              GuideStatus                    @default(DRAFT)
  isActive            Boolean                        @default(true)
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  translations        VehicleGuideCardTranslation[]
  facts               VehicleGuideFact[]
  technicalInfos      VehicleGuideTechnicalInfo[]
  viewHistories       UserGuideCardViewHistory[]
  analyticsEvents     GuideAnalyticsEvent[]
}

model VehicleGuideCardTranslation {
  id                  String            @id @default(uuid())
  vehicleGuideCardId  String
  locale              Locale
  shortSummary        String

  card                VehicleGuideCard  @relation(fields: [vehicleGuideCardId], references: [id], onDelete: Cascade)

  @@unique([vehicleGuideCardId, locale])
}

model VehicleGuideFact {
  id                  String                      @id @default(uuid())
  vehicleGuideCardId  String
  factType            GuideFactType
  title               String
  description         String
  iconKey             String?
  displayOrder        Int                         @default(0)
  confidenceLevel     DataConfidence              @default(HIGH)
  sourceTitle         String?
  sourceUrl           String?
  sourceType          GuideSourceType             @default(INTERNAL_RESEARCH)
  sourceNote          String?
  verifiedAt          DateTime?
  status              GuideStatus                 @default(DRAFT)
  isActive            Boolean                     @default(true)
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  card                VehicleGuideCard            @relation(fields: [vehicleGuideCardId], references: [id], onDelete: Cascade)
  translations        VehicleGuideFactTranslation[]
}

model VehicleGuideFactTranslation {
  id                  String            @id @default(uuid())
  vehicleGuideFactId  String
  locale              Locale
  title               String
  description         String

  fact                VehicleGuideFact  @relation(fields: [vehicleGuideFactId], references: [id], onDelete: Cascade)

  @@unique([vehicleGuideFactId, locale])
}

model VehicleGuideTechnicalInfo {
  id                  String                      @id @default(uuid())
  vehicleGuideCardId  String
  engineOptions       Json?                       // JSON Array: ["1.6 TDI", "2.0 TDI"]
  fuelTypes           Json?                       // JSON Array: ["PETROL", "DIESEL"]
  transmissionOptions Json?                       // JSON Array: ["MANUAL", "DSG"]
  bodyTypes           Json?                       // JSON Array: ["SEDAN", "SUV"]
  productionYears     String?
  averageConsumption  String?
  powerRange          String?
  torqueRange         String?
  drivetrain          String?
  segment             String?
  trunkVolume         String?
  safetyInfo          String?
  sourceTitle         String?
  sourceUrl           String?
  sourceType          GuideSourceType             @default(INTERNAL_RESEARCH)
  verifiedAt          DateTime?
  status              GuideStatus                 @default(DRAFT)
  isActive            Boolean                     @default(true)
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  card                VehicleGuideCard            @relation(fields: [vehicleGuideCardId], references: [id], onDelete: Cascade)
  translations        VehicleGuideTechnicalInfoTranslation[]
}

model VehicleGuideTechnicalInfoTranslation {
  id                           String                    @id @default(uuid())
  vehicleGuideTechnicalInfoId  String
  locale                       Locale
  localizedNotes               String

  technicalInfo                VehicleGuideTechnicalInfo @relation(fields: [vehicleGuideTechnicalInfoId], references: [id], onDelete: Cascade)

  @@unique([vehicleGuideTechnicalInfoId, locale])
}

model UserGuideCardViewHistory {
  id                  String            @id @default(uuid())
  userId              String?
  vehicleGuideCardId  String
  viewedAt            DateTime          @default(now())
  durationMs          Int?
  openedTechnicalInfo Boolean           @default(false)
  clickedListings     Boolean           @default(false)
  createdAt           DateTime          @default(now())

  user                User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  card                VehicleGuideCard  @relation(fields: [vehicleGuideCardId], references: [id], onDelete: Cascade)
}

model GuideAnalyticsEvent {
  id                  String         @id @default(uuid())
  userId              String?
  sessionId           String?
  vehicleGuideCardId  String
  eventType           GuideEventType
  brand               String
  model               String
  generationCode      String?
  durationMs          Int?
  deviceType          String?
  locale              String
  timestamp           DateTime       @default(now())

  card                VehicleGuideCard @relation(fields: [vehicleGuideCardId], references: [id], onDelete: Cascade)
}

model FavoriteSeller {
  id        String   @id @default(uuid())
  userId    String
  sellerId  String
  createdAt DateTime @default(now())

  user      User     @relation("FavoriteSellerUser", fields: [userId], references: [id], onDelete: Cascade)
  seller    User     @relation("FavoriteSellerSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([userId, sellerId])
  @@index([userId])
  @@index([sellerId])
}

model SavedSearch {
  id                 String    @id @default(uuid())
  userId             String
  title              String
  filters            Json
  isEmailAlertActive Boolean   @default(true)
  isPushAlertActive  Boolean   @default(false)
  lastRunAt          DateTime?
  lastMatchedCount   Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Conversation {
  id            String         @id @default(uuid())
  listingId     String
  buyerId       String
  sellerId      String
  lastMessageAt DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  listing       VehicleListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer         User           @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  seller        User           @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@unique([listingId, buyerId, sellerId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

